{
  "name": "@discifi/backend",
  "version": "1.0.0",
  "private": true,
  "description": "DisciFi Sentinel Backend - Fastify API server with Helius RPC, MongoDB, Redis",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "lint": "eslint src/",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests --forceExit",
    "test:coverage": "node --experimental-vm-modules node_modules/.bin/jest --coverage --passWithNoTests --forceExit",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@discifi/shared": "workspace:*",
    "@fastify/cors": "^9.0.0",
    "@fastify/rate-limit": "^9.0.0",
    "fastify": "^4.26.0",
    "ioredis": "^5.4.0",
    "jsonwebtoken": "^9.0.0",
    "mongoose": "^8.0.0",
    "pino": "^8.17.0",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "winston": "^3.11.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.11.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.7.0",
    "typescript": "^5.5.0"
  }
}
