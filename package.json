{
  "name": "discifi",
  "version": "1.0.0",
  "private": true,
  "description": "DisciFi Sentinel - Production-grade, privacy-first, drain-proof hardware wallet system",
  "workspaces": [
    "packages/*",
    "apps/*",
    "contracts/*"
  ],
  "scripts": {
    "mobile": "cd apps/mobile && npx expo start",
    "mobile:ios": "cd apps/mobile && npx expo run:ios",
    "mobile:android": "cd apps/mobile && npx expo run:android",
    "build": "turbo run build --filter=./packages/* --filter=./apps/*",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "backend:dev": "turbo run dev --filter=@discifi/backend",
    "backend:build": "turbo run build --filter=@discifi/backend",
    "backend:start": "node apps/backend/dist/server.js",
    "contracts:test": "ANCHOR_PROVIDER_URL=https://api.devnet.solana.com ANCHOR_WALLET=~/.config/solana/id.json pnpm ts-mocha -p contracts/sentinel/tests/tsconfig.json -t 1000000 contracts/sentinel/tests/sentinel.ts",
    "contracts:build": "anchor build",
    "contracts:deploy": "anchor deploy --provider.cluster devnet"
  },
  "devDependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@types/chai": "^5.2.3",
    "@types/react": "~19.2.14",
    "chai": "^6.2.2",
    "prettier": "^3.2.0",
    "ts-mocha": "^11.1.0",
    "tsx": "^4.22.4",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.2",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.2",
    "@react-navigation/native": "^7.3.3",
    "@react-navigation/native-stack": "^7.17.5",
    "@scure/bip39": "^2.2.0",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "1",
    "bs58": "^6.0.0",
    "buffer": "^6.0.3",
    "eventemitter3": "^5.0.4",
    "expo": "~56.0.8",
    "expo-clipboard": "~56.0.4",
    "expo-crypto": "^56.0.4",
    "expo-screen-capture": "^56.0.4",
    "expo-secure-store": "^56.0.4",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3",
    "react-native-get-random-values": "^2.0.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.25.2",
    "react-native-svg": "15.15.4",
    "tweetnacl": "^1.0.3"
  }
}
