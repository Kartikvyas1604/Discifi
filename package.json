{
  "name": "discifi",
  "version": "1.0.0",
  "private": true,
  "description": "DisciFi Sentinel - Production-grade, privacy-first, drain-proof hardware wallet system",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "backend:dev": "turbo run dev --filter=@discifi/backend",
    "backend:build": "turbo run build --filter=@discifi/backend",
    "backend:start": "node apps/backend/dist/server.js"
  },
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.15.0"
}
